# ==============================================
# AMBIENTE
# ==============================================
NODE_ENV=development
PORT=3007

# ==============================================
# BANCO DE DADOS (Docker local)
# ==============================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5439/sports_news"

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sports_news

# ==============================================
# JWT (Auth)
# ==============================================
JWT_SECRET=sports_news_jwt_secret_troque_em_producao
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ==============================================
# CLOUDINARY (Upload de imagens)
# Crie conta em cloudinary.com e preencha
# ==============================================
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret
CLOUDINARY_FOLDER=sports-news

# ==============================================
# CORS
# ==============================================
ALLOWED_ORIGINS=http://localhost:3007,http://localhost:3000

# ==============================================
# ADMIN INICIAL (usado no seed)
# ==============================================
SEED_ADMIN_EMAIL=admin@seusite.com.br
SEED_ADMIN_PASSWORD=troque_essa_senha
SEED_ADMIN_NAME=Administrador

# ==============================================
# PLACAR AO VIVO — football-data.org
# ==============================================
FOOTBALL_DATA_API_KEY=sua_chave_aqui