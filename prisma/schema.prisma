// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USUÁRIOS DO PAINEL ADMIN
// ============================================================
enum Role {
  SUPER_ADMIN
  EDITOR_CHEFE
  EDITOR
  JORNALISTA
  COLUNISTA
  SOCIAL_MEDIA
  MODERADOR
  SEO_MANAGER
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(JORNALISTA)
  avatar       String?  // URL da foto no Cloudinary
  bio          String?
  position     String?  // Cargo exibível (ex: "Editor-Chefe", "Repórter")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  articles      Article[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ============================================================
// CATEGORIAS / MODALIDADES ESPORTIVAS
// ============================================================
model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  color       String?   // Cor hex para destaque visual (#FF0000)
  icon        String?   // Nome do ícone (ex: "football", "basketball")
  isActive    Boolean   @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  articles    Article[]

  @@map("categories")
}

// ============================================================
// TAGS
// ============================================================
model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  articles  ArticleTag[]

  @@map("tags")
}

// ============================================================
// ARTIGOS / NOTÍCIAS
// ============================================================
enum ArticleStatus {
  DRAFT      // Rascunho — só o autor vê
  REVIEW     // Aguardando revisão do editor
  PUBLISHED  // Publicado e visível
  ARCHIVED   // Arquivado — fora do ar mas mantido
}

enum ArticleType {
  NEWS        // Notícia padrão
  ANALYSIS    // Análise / opinião
  INTERVIEW   // Entrevista
  LIVE        // Cobertura ao vivo
  GALLERY     // Galeria de fotos
}

model Article {
  id              String        @id @default(uuid())
  title           String
  subtitle        String?       // Linha fina / chamada
  slug            String        @unique
  content         String        // HTML ou Markdown rico
  excerpt         String?       // Resumo para listagens e SEO
  status          ArticleStatus @default(DRAFT)
  type            ArticleType   @default(NEWS)
  isFeatured      Boolean       @default(false)
  isBreaking      Boolean       @default(false)
  isPinned        Boolean       @default(false)

  // Capa
  coverImage      String?
  coverImageAlt   String?
  coverImageCredit String?

  // Relacionamentos
  authorId        String
  categoryId      String
  author          User          @relation(fields: [authorId], references: [id])
  category        Category      @relation(fields: [categoryId], references: [id])
  tags            ArticleTag[]
  images          ArticleImage[]

  // SEO
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?

  viewCount       Int           @default(0)

  publishedAt     DateTime?
  scheduledAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([authorId])
  @@index([slug])
  @@map("articles")
}

// ============================================================
// GALERIA DE IMAGENS POR ARTIGO
// ============================================================
model ArticleImage {
  id        String   @id @default(uuid())
  url       String
  alt       String?
  caption   String?
  credit    String?
  order     Int      @default(0)
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("article_images")
}

// ============================================================
// RELAÇÃO N:N ARTIGO <-> TAG
// ============================================================
model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

// ============================================================
// MENU DE NAVEGAÇÃO
// ============================================================
model MenuItem {
  id        String     @id @default(uuid())
  label     String
  url       String
  target    String     @default("_self")
  order     Int        @default(0)
  parentId  String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())  // ← adicione essa linha

  parent    MenuItem?  @relation("MenuHierarchy", fields: [parentId], references: [id])
  children  MenuItem[] @relation("MenuHierarchy")

  @@unique([label, parentId])
  @@map("menu_items")
}

// ============================================================
// BANNERS
// ============================================================
model Banner {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String
  linkUrl     String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("banners")
}

// ============================================================
// CONFIGURAÇÕES GERAIS DO SITE
// ============================================================
model SiteSettings {
  id               String  @id @default("main")
  siteName         String  @default("Portal Esportivo")
  siteDescription  String?
  logoUrl          String?
  faviconUrl       String?
  primaryColor     String  @default("#E63946")
  socialFacebook   String?
  socialInstagram  String?
  socialTwitter    String?
  socialYoutube    String?
  googleAnalytics  String?
  footerText       String?
  updatedAt        DateTime @updatedAt

  @@map("site_settings")
}